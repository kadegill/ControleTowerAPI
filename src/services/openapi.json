            "type": "integer",
            "example": 1
          },
          "AIRPORT_NAME": {
            "type": "string",
            "example": "Des Moines International Airport"
          },
          "AIRPORT_CITY": {
            "type": "string",
            "example": "Des Moines"
          },
          "AIRPORT_COUNTRY": {
            "type": "string",
            "example": "Canada"
