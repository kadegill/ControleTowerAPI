          "AIRPORT_LATITUDE": {
            "type": "number",
            "example": "49.91"
          },
          "AIRPORT_LONGITUDE": {
            "type": "number",
            "example": "-99.951897"
          },
          "AIRPORT_TIMEZONE": {
            "type": "string",
            "example": "America/Vancouver"
          },
          "AIRPORT_TYPE": {
            "type": "string",
